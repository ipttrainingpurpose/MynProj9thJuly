{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "rootDir": "./tests",
    "outDir": "./dist",
    "types": ["node", "playwright"]
    
  },
  "include": [
    "tests/**/*.ts",
    "tests/**/*.js"
  ]
}